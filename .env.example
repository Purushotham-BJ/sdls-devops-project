# ============================================================
# Smart Distributed Logging System — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── JWT Auth (API Gateway) ───────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=distributed_logging

# ── Service Ports ────────────────────────────────────────────
API_GATEWAY_PORT=5000
ORDER_SERVICE_PORT=5001
PAYMENT_SERVICE_PORT=5002
INVENTORY_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004
LOGGING_SERVICE_PORT=5005
DASHBOARD_PORT=5006

# ── Internal Service URLs (used inside Docker network) ───────
ORDER_SERVICE_URL=http://order-service:5001
PAYMENT_SERVICE_URL=http://payment-service:5002
INVENTORY_SERVICE_URL=http://inventory-service:5003
NOTIFICATION_SERVICE_URL=http://notification-service:5004
LOGGING_SERVICE_URL=http://logging-service:5005

# ── DockerHub ────────────────────────────────────────────────
DOCKERHUB_USERNAME=yourdockerhubusername
DOCKERHUB_REPO_PREFIX=yourdockerhubusername

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0

# ── Log Level ────────────────────────────────────────────────
LOG_LEVEL=INFO
